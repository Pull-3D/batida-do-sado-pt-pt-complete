{
  "name": "batida-do-sado",
  "version": "1.0.0",
  "description": "Batida do Sado DJ tool da margem do Sado",
  "author": {
    "name": "Charroco"
  },
  "homepage": "",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "build:mac": "vite build && electron-builder --mac --universal",
    "build:win": "vite build && electron-builder --win --x64",
    "build:win-arm64": "vite build && electron-builder --win --arm64",
    "build:linux": "vite build && electron-builder --linux --x64",
    "build:linux-arm64": "vite build && electron-builder --linux --arm64",
    "build:mac-arm64": "vite build && electron-builder --mac --arm64",
    "build:all": "vite build && electron-builder --mac --universal && electron-builder --mac --arm64 && electron-builder --win --x64 && electron-builder --win --arm64 && electron-builder --linux --x64 && electron-builder --linux --arm64",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\""
  },
  "dependencies": {
    "aes-js": "^3.1.2",
    "axios": "^1.6.0",
    "deezer-js": "^1.3.8",
    "egoroof-blowfish": "^4.0.2",
    "flac-metadata": "^0.1.1",
    "node-id3": "^0.2.9",
    "pinia": "^2.1.0",
    "socket.io-client": "^4.7.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.7.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^3.2.1"
  },
  "build": {
    "appId": "pt.charroco.batidadosado",
    "productName": "Batida do Sado",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "Audio"
    }
  }
}
